// colors
:root
  // dark theme
  --clr-bg #2D3035
  --clr-bg-light #393E46
  --clr-bg-lighter #505661
  --grad-aside-btn linear-gradient(0deg, #393e46 0, #505661 100%)
  --clr-accent #FFD369
  --clr-accent-hover #FFE7AD
  --clr-txt #EEEEEE
  --clr-txt-darker #7E8998
  --clr-help-bg rgba(0, 0, 0, 0.8)
  --clr-help-txt #ffffff

// font
:root
  --font-family 'Arial', 'Helvetica', 'sans-serif'
  --font-h1 600 52px/54px var(--font-family)
  --margin-h1 40px
  --font-h2 500 32px/36px var(--font-family)
  --margin-h2 28px
  --font-h3 500 24px/28px var(--font-family)
  --margin-h3 20px
  --font-base 400 18px/24px var(--font-family)
  --margin-base 20px
  --font-small 400 14px/18px var(--font-family)
  --margin-small 12px
  --font-tiny 300 12px/14px var(--font-family)
  --margin-tiny 8px
  @media (max-width: 1200px)
    --font-h1 600 44px/48px var(--font-family)
    --margin-h1 32px
    --font-h2 500 28px/32px var(--font-family)
    --margin-h2 24px
    --font-h3 500 22px/26px var(--font-family)
    --font-base 400 16px/20px var(--font-family)
  @media (max-width: 600px)
    --font-h1 600 28px/32px var(--font-family)
    --margin-h1 28px
    --font-h2 500 24px/28px var(--font-family)
    --margin-h2 20px
    --font-h3 500 20px/24px var(--font-family)
    --margin-h3 12px
    --font-base 400 14px/18px var(--font-family)
    --margin-base 12px
    --font-small 400 12px/16px var(--font-family)
    --margin-small 8px
    --font-tiny 300 10px/12px var(--font-family)
    --margin-tiny 6px

*, *::after, *::before
  box-sizing border-box

body 
  position relative
  margin 0
  padding 0
  font-family var(--font-family)
  background var(--clr-bg)
  color var(--clr-txt)

h1, h2, h3, p
  margin 0

.container
  margin 0 auto
  max-width 1280px
  width 100%
  padding 0 16px

.tictactoe
  position relative
  display flex
  flex-direction column
  align-items center
  gap 20px
  margin 40px 0
  padding 24px
  background var(--clr-bg-lighter)
  border-radius 12px
  &__title  
    text-align center
    font-size 32px
    line-height 1.15
    margin-bottom 60px
  &__text
    font-size 24px
    line-height 1.15
  &__restart
    display flex
    justify-content center
    &-btn
      position relative
  &__field
    position relative
    &::after
      content ''
      position absolute
      top 0
      left 0
      bottom 0
      right 0
      display flex
      justify-content center
      align-items center
      background rgba(46, 58, 56, 0.25)
      font-size 24px
      line-height 1.15
      color white
      text-shadow 0 0 12px black
      visibility hidden
      opacity 0
      pointer-events none
      transition .3s ease
    &.--is-won::after
      visibility visible
      opacity 1
      pointer-events all
    &._pl1::after
      content '(X) won'
    &._pl2::after
      content '(O) won'
  &__table
    border-collapse collapse
    &-row
      &-cell
        border 1px solid gray
        &-symbol
          padding 0
          background transparent
          outline 0
          border none
          cursor pointer
          width 80px
          height 80px
          display flex
          justify-content center
          align-items center
          font-size 48px
          line-height 1
          opacity .75
          transition .3s ease
          &::before
            transition .3s ease
          &._tic
            &::before
              content 'X'
              color rgb(255,255,0)
              color var(--pl-1)
              font inherit
          &._tac
            &::before
              content 'O'
              color rgb(255,0,255)
              color var(--pl-2)
              font inherit
          &._protecc
            opacity 1
            pointer-events none
            &::before
              text-shadow 0 0 32px currentColor
  &__settings
    margin-top 40px
    display flex
    flex-direction column
    gap 12px
    &-row
      display flex
      align-items center
      gap 20px
      &-name
        font-size 18px
        line-height 1
      &-color
        padding 0
        height 24px
        width 32px
        background transparent
        border 1px solid white
        border-radius 4px